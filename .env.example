# ── DATABASE ──
DATABASE_URL="postgresql://fiscx:fiscx_password@localhost:5432/fiscx_dev"
POSTGRES_USER=fiscx
POSTGRES_PASSWORD=fiscx_password
POSTGRES_DB=fiscx_dev

# ── REDIS ──
REDIS_URL="redis://localhost:6379"

# ── API ──
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production_128_chars_min
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me_in_production_128_chars_min
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ── FRONTEND ──
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=FiscX

# ── QR CODE & VERIFICATION ──
QR_VERIFY_BASE_URL=https://fiscx.bj/verify
QR_HMAC_SECRET=your_qr_hmac_secret_change_me_in_production

# ── EMAIL (for future use) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── MOBILE MONEY (MTN, Moov) ──
MTN_API_KEY=your_mtn_api_key
MTN_API_SECRET=your_mtn_api_secret
MOOV_API_KEY=your_moov_api_key
MOOV_API_SECRET=your_moov_api_secret

# ── KYC PROVIDER (Smile Identity) ──
SMILE_API_KEY=your_smile_api_key
SMILE_API_SECRET=your_smile_api_secret

# ── LOGGING ──
LOG_LEVEL=debug

# ── SECURITY ──
BCRYPT_ROUNDS=10
API_RATE_LIMIT=100
